---
import WorkspaceLayout from "../../layouts/WorkspaceLayout.astro";
import { ProjectCanvasList } from "../../components/canvas/ProjectCanvasList";
import { QuickCreateCanvasButton } from "../../components/canvas/QuickCreateCanvasButton";
---

<WorkspaceLayout title="Canvas">
  <div class="max-w-6xl">
    <section class="rounded-[30px] border border-[#2B313B] bg-[#14171D]/86 p-7 shadow-[0_24px_80px_rgba(0,0,0,0.35)] backdrop-blur-xl">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-[#28D7F5]">Infinite Canvas</p>
      <h2 class="text-3xl font-bold tracking-[-0.04em]">创建或继续你的生成工作流。</h2>
      <p class="mt-3 max-w-xl text-sm leading-6 text-[#B8C0CC]">项目是工作容器；每个项目下可以保存多个画布。</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/generate" class="inline-flex rounded-full bg-[#F5F7FA] px-5 py-2.5 text-sm font-semibold text-[#050608] hover:bg-white">
          图片生成工作台
        </a>
        <QuickCreateCanvasButton
          client:only="react"
          className="inline-flex items-center gap-2 rounded-full border border-[#28D7F5]/40 bg-[#071F2A]/72 px-5 py-2.5 text-sm font-semibold text-[#91F0FF] hover:border-[#28D7F5]/70 disabled:opacity-70"
        >
          快速新建画布
        </QuickCreateCanvasButton>
        <a href="/gallery" class="inline-flex rounded-full border border-[#28D7F5]/40 bg-[#071F2A]/72 px-5 py-2.5 text-sm font-semibold text-[#91F0FF] hover:border-[#28D7F5]/70">
          查看素材库
        </a>
      </div>
    </section>
    <ProjectCanvasList client:only="react" />
  </div>
</WorkspaceLayout>

---
import WorkspaceLayout from "../layouts/WorkspaceLayout.astro";
import RedeemForm from "../components/react/RedeemForm.tsx";
import CreditBalance from "../components/react/CreditBalance.tsx";
---

<WorkspaceLayout title="Credits">
  <div class="max-w-3xl">
    <div class="rounded-[28px] border border-[#2B313B] bg-[#14171D]/86 p-6 shadow-[0_24px_80px_rgba(0,0,0,0.35)] backdrop-blur-xl">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-[#28D7F5]">Public Quota</p>
      <h2 class="text-2xl font-bold tracking-[-0.03em]">公益额度</h2>
      <p class="mt-3 max-w-xl text-sm leading-6 text-[#B8C0CC]">查看当前可用的创作额度。额度用于公平分配图片和视频生成资源。</p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div class="rounded-[22px] border border-[#2B313B] bg-[#0A0C11]/72 p-4">
          <CreditBalance client:only="react" variant="stat" label="Available Quota" />
        </div>
      </div>
      <div class="mt-4">
        <RedeemForm client:only="react" />
      </div>
    </div>
  </div>
</WorkspaceLayout>

---
import WorkspaceLayout from "../layouts/WorkspaceLayout.astro";
import { GenerationGallery } from "../components/canvas/GenerationGallery";
---

<WorkspaceLayout title="Gallery">
  <div class="max-w-7xl">
    <div class="mb-6 overflow-hidden rounded-[32px] border border-[#2B313B] bg-[#14171D]/86 p-7 shadow-[0_24px_80px_rgba(0,0,0,0.35)] backdrop-blur-xl">
      <div class="pointer-events-none absolute right-10 top-24 h-40 w-40 rounded-full bg-[#28D7F5]/15 blur-3xl"></div>
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[#28D7F5]">Personal Asset Archive</p>
      <h2 class="mt-3 max-w-3xl text-4xl font-bold tracking-[-0.05em]">所有项目和画布里的生成结果，都在这里归档。</h2>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-[#B8C0CC]">
        按项目、画布和状态筛选，快速回看历史结果图、提示词和生成参数。
      </p>
    </div>

    <div class="rounded-[32px] border border-[#2B313B] bg-[#0A0C11]/76 p-5 shadow-[0_24px_80px_rgba(0,0,0,0.3)] backdrop-blur-xl">
      <GenerationGallery client:only="react" mode="page" />
    </div>
  </div>
</WorkspaceLayout>

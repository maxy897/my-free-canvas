---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="darkroom-grid flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-sm rounded-[28px] border border-[#39E58C]/30 bg-[#14171D]/90 p-8 text-center shadow-[0_24px_80px_rgba(0,0,0,0.45)] backdrop-blur-xl">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full border border-[#39E58C]/40 bg-[#113325] text-3xl text-[#39E58C]">✓</div>
      <h1 class="mb-2 text-2xl font-bold tracking-[-0.03em]">额度已更新</h1>
      <p class="mb-6 text-sm leading-6 text-[#B8C0CC]">你的公益创作额度已同步到账户。</p>
      <a href="/dashboard" class="inline-block rounded-full bg-[#F5F7FA] px-6 py-2.5 text-sm font-semibold text-[#050608]">
        返回工作台
      </a>
    </div>
  </div>
</BaseLayout>

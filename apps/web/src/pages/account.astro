---
import WorkspaceLayout from "../layouts/WorkspaceLayout.astro";
---

<WorkspaceLayout title="Account">
  <div class="max-w-3xl">
    <div class="rounded-[28px] border border-[#2B313B] bg-[#14171D]/86 p-6 shadow-[0_24px_80px_rgba(0,0,0,0.35)] backdrop-blur-xl">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-[#28D7F5]">Profile</p>
      <h2 class="text-2xl font-bold tracking-[-0.03em]">Account Settings</h2>
      <p class="mt-3 max-w-xl text-sm leading-6 text-[#B8C0CC]">管理账户资料和创作偏好。这里会逐步承载公益项目的协作设置、通知和安全信息。</p>
      <div class="mt-6 rounded-[22px] border border-[#2B313B] bg-[#0A0C11]/72 p-4">
        <div class="text-xs uppercase tracking-[0.18em] text-[#788493]">Status</div>
        <div class="mt-3 text-lg font-semibold">Ready</div>
      </div>
    </div>
  </div>
</WorkspaceLayout>

---
import { ClientRouter } from "astro:transitions";
import AnnouncementBanner from "../components/react/AnnouncementBanner.tsx";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Free Canvas</title>
    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg?v=2" />
    <link rel="shortcut icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <meta name="theme-color" content="#050608" />
    <ClientRouter />
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Satoshi:wght@400;500;600;700&display=swap');
      @import "tailwindcss";

      @theme {
        --color-primary: #2563EB;
        --color-primary-light: #DBEAFE;
        --color-ai-purple: #8B5CF6;
        --color-ai-blue: #6366F1;
        --color-ai-video: #3B82F6;
        --color-surface: #FFFFFF;
        --color-canvas-light: #F5F5F7;
        --color-border-light: #E5E7EB;
        --color-text-light: #1F2937;
        --color-text-secondary: #6B7280;
        --color-text-muted: #9CA3AF;
        --font-sans: 'Plus Jakarta Sans', system-ui, sans-serif;
      }

      :root {
        color-scheme: dark;
        --color-canvas: #050608;
        --color-canvas-deep: #02040a;
        --color-canvas-grid: #1d2430;
        --color-surface: #14171d;
        --color-surface-raised: #1d2129;
        --color-surface-glass: rgba(24, 28, 35, 0.78);
        --color-border: #2b313b;
        --color-border-strong: #3c4654;
        --color-text: #f5f7fa;
        --color-muted: #b8c0cc;
        --color-dim: #788493;
        --color-cyan: #28d7f5;
        --color-amber: #ffb454;
        --color-violet: #9b7cff;
        --color-green: #39e58c;
        --color-danger: #ff5c7a;
        
        /* Typography Scale */
        --font-title: 'Satoshi', system-ui, sans-serif;
        --font-body: MiSans, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
        --font-mono: 'Courier New', 'Monaco', monospace;
        
        /* Type Sizes */
        --text-xs: 0.75rem;
        --text-sm: 0.875rem;
        --text-base: 1rem;
        --text-lg: 1.125rem;
        --text-xl: 1.25rem;
        --text-2xl: 1.5rem;
        --text-3xl: 1.875rem;
      }

      html {
        background: var(--color-canvas);
      }

      body {
        font-family: MiSans, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
        background:
          radial-gradient(circle at 18% 12%, rgba(40, 215, 245, 0.12), transparent 30rem),
          radial-gradient(circle at 84% 16%, rgba(155, 124, 255, 0.14), transparent 26rem),
          linear-gradient(180deg, #080b12 0%, var(--color-canvas) 52%, #020307 100%);
      }

      ::selection {
        background: rgba(40, 215, 245, 0.28);
        color: var(--color-text);
      }

      * {
        scrollbar-color: #3c4654 #11141a;
      }

      .darkroom-grid {
        background:
          radial-gradient(circle at 16% 18%, rgba(40, 215, 245, 0.08), transparent 22rem),
          radial-gradient(circle at 52% 0%, rgba(99, 102, 241, 0.12), transparent 36rem),
          radial-gradient(circle at 86% 22%, rgba(155, 124, 255, 0.1), transparent 30rem),
          linear-gradient(rgba(255, 255, 255, 0.026) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.026) 1px, transparent 1px),
          var(--color-canvas-deep);
        background-size: auto, auto, auto, 48px 48px, 48px 48px, auto;
      }

      .darkroom-no-grid {
        background:
          radial-gradient(circle at 16% 18%, rgba(40, 215, 245, 0.08), transparent 22rem),
          radial-gradient(circle at 52% 0%, rgba(99, 102, 241, 0.12), transparent 36rem),
          radial-gradient(circle at 86% 22%, rgba(155, 124, 255, 0.1), transparent 30rem),
          var(--color-canvas-deep);
      }

      .darkroom-canvas::before {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        content: "";
        background:
          linear-gradient(115deg, rgba(255, 255, 255, 0.055), transparent 18%, transparent 78%, rgba(139, 92, 246, 0.08)),
          radial-gradient(circle at 50% 110%, rgba(40, 215, 245, 0.06), transparent 34rem);
        opacity: 0.95;
      }

      .darkroom-canvas::after {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        content: "";
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
        background-position: -1px -1px;
        background-size: 12px 12px;
        mask-image: radial-gradient(circle at 50% 45%, black, transparent 78%);
        opacity: 0.22;
      }

      .darkroom-canvas .react-flow {
        position: relative;
        z-index: 1;
      }

      .darkroom-canvas .react-flow__pane {
        cursor: crosshair;
      }

      .darkroom-canvas button,
      .darkroom-canvas [role="button"] {
        cursor: pointer;
      }

      .darkroom-canvas button:focus-visible,
      .darkroom-canvas input:focus-visible,
      .darkroom-canvas textarea:focus-visible,
      .darkroom-canvas select:focus-visible {
        outline: 2px solid rgba(40, 215, 245, 0.85);
        outline-offset: 2px;
      }

      .darkroom-canvas .react-flow__minimap {
        overflow: hidden;
        border: 1px solid rgba(60, 70, 84, 0.68) !important;
        border-radius: 18px;
        background: rgba(12, 14, 18, 0.86) !important;
        box-shadow: 0 18px 55px rgba(0, 0, 0, 0.34);
        backdrop-filter: blur(18px);
      }

      .darkroom-canvas .react-flow__minimap svg {
        background: #0a0c11 !important;
      }

      .darkroom-canvas .react-flow__minimap-mask {
        fill: rgba(5, 6, 8, 0.62) !important;
      }

      .darkroom-canvas .custom-canvas-minimap {
        position: absolute !important;
        inset: 0 !important;
        border-radius: 22px !important;
      }

      .darkroom-canvas .custom-canvas-minimap svg {
        width: 100% !important;
        height: 100% !important;
        background: rgba(24, 24, 27, 0.92) !important;
      }

      .darkroom-canvas .custom-canvas-minimap .react-flow__minimap-node {
        fill: rgba(90, 90, 99, 0.55) !important;
        stroke: rgba(255, 255, 255, 0.58) !important;
      }

      .darkroom-canvas .custom-canvas-minimap .react-flow__minimap-mask {
        fill: transparent !important;
        stroke: transparent !important;
      }

      .darkroom-canvas .canvas-zoom-slider {
        width: 76px;
        height: 18px;
        appearance: none;
        background: transparent;
        cursor: pointer;
      }

      .darkroom-canvas .canvas-zoom-slider::-webkit-slider-runnable-track {
        height: 6px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.18);
      }

      .darkroom-canvas .canvas-zoom-slider::-webkit-slider-thumb {
        appearance: none;
        width: 18px;
        height: 18px;
        margin-top: -6px;
        border: 2px solid #ffffff;
        border-radius: 999px;
        background: #ffffff;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.3);
      }

      .darkroom-canvas .canvas-zoom-slider::-moz-range-track {
        height: 6px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.18);
      }

      .darkroom-canvas .canvas-zoom-slider::-moz-range-thumb {
        width: 18px;
        height: 18px;
        border: 2px solid #ffffff;
        border-radius: 999px;
        background: #ffffff;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.3);
      }

      .darkroom-canvas select,
      .darkroom-canvas option {
        color-scheme: dark;
        background: #14171d;
        color: var(--color-text);
      }

      .darkroom-canvas .react-flow__edge-path {
        stroke: rgba(40, 215, 245, 0.38);
        stroke-width: 3;
        transition: stroke 0.3s ease, stroke-width 0.3s ease;
      }

      .darkroom-canvas .react-flow__edge.selected .react-flow__edge-path,
      .darkroom-canvas .react-flow__edge:hover .react-flow__edge-path {
        stroke: var(--color-cyan);
        stroke-width: 4;
        filter: drop-shadow(0 0 8px rgba(40, 215, 245, 0.45));
      }

      .darkroom-canvas .react-flow__selection {
        border: 1px solid rgba(99, 102, 241, 0.72);
        background: rgba(99, 102, 241, 0.08);
      }

      .darkroom-canvas .react-flow__node.selected > .canvas-node {
        border-color: rgba(40, 215, 245, 0.82);
        box-shadow:
          0 0 0 1px rgba(40, 215, 245, 0.32),
          0 24px 48px -12px rgba(0, 0, 0, 0.4),
          0 0 32px rgba(40, 215, 245, 0.2),
          inset 0 1px 0 rgba(255, 255, 255, 0.1);
        transform: translateY(-2px);
      }

      .canvas-node {
        position: relative;
        overflow: visible;
        border: 1px solid var(--node-glow, rgba(255, 255, 255, 0.15));
        background:
          linear-gradient(180deg, rgba(29, 33, 41, 0.96), rgba(13, 16, 22, 0.96)),
          rgba(20, 23, 29, 0.95);
        box-shadow:
          0 18px 44px rgba(0, 0, 0, 0.42),
          0 0 0 1px rgba(0, 0, 0, 0.6),
          inset 0 1px 0 rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(24px);
        transition: border-color 0.22s ease, box-shadow 0.22s ease, transform 0.22s ease;
      }
      
      .canvas-node:hover {
        border-color: var(--node-accent, rgba(255, 255, 255, 0.4));
        box-shadow:
          0 12px 32px rgba(0, 0, 0, 0.45),
          0 0 0 1px rgba(0, 0, 0, 0.6),
          inset 0 1px 0 rgba(255, 255, 255, 0.12),
          0 0 20px var(--node-glow, rgba(40, 215, 245, 0.15));
      }

      .canvas-node::before {
        position: absolute;
        inset: 0;
        pointer-events: none;
        border-radius: inherit;
        content: "";
        background:
          radial-gradient(circle at 0% 0%, var(--node-glow, rgba(40, 215, 245, 0.18)), transparent 15rem),
          linear-gradient(90deg, var(--node-accent, rgba(40, 215, 245, 0.7)), transparent 42%);
        opacity: 0.12;
      }

      .canvas-node > :not(.react-flow__handle) {
        position: relative;
        z-index: 1;
      }

      .canvas-node .react-flow__handle {
        z-index: 2;
      }
      
      .canvas-node .react-flow__handle:hover {
        box-shadow: 0 0 22px currentColor, 0 0 0 5px rgba(0, 0, 0, 0.42) !important;
      }

      .canvas-node-header {
        border-top-left-radius: inherit;
        border-top-right-radius: inherit;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.012)),
          rgba(0, 0, 0, 0.2);
      }

      .canvas-field {
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(4, 7, 12, 0.5);
        box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.15);
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
      }

      .canvas-field.border-dashed {
        border-style: dashed;
      }

      .canvas-primary-button {
        background:
          linear-gradient(180deg, #ffffff, #d9e3f1);
        color: #050608;
        box-shadow:
          0 12px 32px rgba(245, 247, 250, 0.18),
          inset 0 1px 0 rgba(255, 255, 255, 0.88);
      }

      .canvas-primary-button:hover {
        filter: brightness(1.04);
      }

      /* Monospace/Technical Text Utility */
      .mono-text {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.02em;
        line-height: 1.5;
        color: var(--color-dim);
      }
      
      .mono-text.highlight {
        color: var(--color-cyan);
        background: rgba(40, 215, 245, 0.08);
        padding: 0.125rem 0.375rem;
        border-radius: 3px;
      }
      
      /* Typography Utility Classes */
      .text-title {
        font-family: var(--font-title);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.2;
      }
      
      .text-title-lg {
        font-size: var(--text-3xl);
        font-family: var(--font-title);
        font-weight: 700;
      }
      
      .text-title-md {
        font-size: var(--text-2xl);
        font-family: var(--font-title);
        font-weight: 700;
      }
      
      .text-title-sm {
        font-size: var(--text-lg);
        font-family: var(--font-title);
        font-weight: 600;
      }
      
      .text-subtitle {
        font-size: var(--text-sm);
        color: var(--color-dim);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      
      /* Canvas Node Typography */
      .canvas-node-label {
        font-family: var(--font-title);
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--color-text);
      }
      
      .canvas-node-hint {
        font-family: var(--font-body);
        font-size: var(--text-xs);
        color: var(--color-dim);
        line-height: 1.4;
      }

      @media (prefers-reduced-motion: reduce) {
        .darkroom-canvas *,
        .darkroom-canvas *::before,
        .darkroom-canvas *::after {
          scroll-behavior: auto !important;
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
        }
      }

      /* New Light Theme Node Styles */
      .node-card {
        transition: box-shadow 0.2s ease, transform 0.2s ease;
      }
      .node-card:hover {
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.08), 0 4px 10px -5px rgba(0,0,0,0.03);
      }
      .glow-purple {
        box-shadow: 0 0 0 1px rgba(139,92,246,0.2), 0 4px 20px rgba(139,92,246,0.08);
      }
      .glow-blue {
        box-shadow: 0 0 0 1px rgba(99,102,241,0.2), 0 4px 20px rgba(99,102,241,0.08);
      }
      @keyframes breathe {
        0%, 100% { opacity: 0.5; transform: scale(0.95); }
        50% { opacity: 1; transform: scale(1.05); }
      }
      .animate-breathe {
        animation: breathe 2.5s ease-in-out infinite;
      }
      @keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
      }
      @keyframes pulse-ring {
        0% { transform: scale(1); opacity: 1; }
        100% { transform: scale(1.8); opacity: 0; }
      }
    </style>
  </head>
  <body class="min-h-screen bg-[#050608] text-[#F5F7FA] antialiased">
    <AnnouncementBanner client:only="react" />
    <slot />
  </body>
</html>

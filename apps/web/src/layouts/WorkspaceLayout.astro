---
import BaseLayout from "./BaseLayout.astro";
import AuthButton from "../components/react/AuthButton.tsx";
import AnnouncementBell from "../components/react/AnnouncementBell.tsx";

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<BaseLayout>
  <div class="flex min-h-screen bg-[#050608] text-[#F5F7FA]">
    <!-- Sidebar -->
    <aside class="hidden w-64 border-r border-[#2B313B] bg-[#0A0C11]/86 p-4 backdrop-blur-xl md:block">
      <a href="/" class="mb-8 flex items-center gap-3 px-2">
        <img src="/brand/free-canvas-mark.svg" alt="" class="h-8 w-8" />
        <span>
          <span class="block text-sm font-bold tracking-tight">Free Canvas</span>
          <span class="block text-[10px] uppercase tracking-[0.2em] text-[#788493]">AI Darkroom</span>
        </span>
      </a>
      <nav class="space-y-1">
        <a href="/dashboard" class="block rounded-2xl px-3 py-2 text-sm font-medium text-[#B8C0CC] transition hover:bg-[#1D2129] hover:text-[#F5F7FA]">Dashboard</a>
        <a href="/generate" class="block rounded-2xl px-3 py-2 text-sm font-medium text-[#B8C0CC] transition hover:bg-[#1D2129] hover:text-[#F5F7FA]">Generate</a>
        <a href="/canvas" class="block rounded-2xl px-3 py-2 text-sm font-medium text-[#B8C0CC] transition hover:bg-[#1D2129] hover:text-[#F5F7FA]">Canvas</a>
        <a href="/gallery" class="block rounded-2xl px-3 py-2 text-sm font-medium text-[#B8C0CC] transition hover:bg-[#1D2129] hover:text-[#F5F7FA]">Gallery</a>
        <a href="/credits" class="block rounded-2xl px-3 py-2 text-sm font-medium text-[#B8C0CC] transition hover:bg-[#1D2129] hover:text-[#F5F7FA]">Credits</a>
        <a href="/account" class="block rounded-2xl px-3 py-2 text-sm font-medium text-[#B8C0CC] transition hover:bg-[#1D2129] hover:text-[#F5F7FA]">Account</a>
      </nav>
    </aside>

    <!-- Main content -->
    <div class="flex-1 flex flex-col">
      <!-- Header -->
      <header class="relative z-50 flex items-center justify-between border-b border-[#2B313B] bg-[#0A0C11]/78 px-6 py-3 backdrop-blur-xl">
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-[#28D7F5]">Workspace</p>
          <h1 class="mt-0.5 text-lg font-semibold tracking-tight">{title}</h1>
        </div>
        <div class="flex items-center gap-3">
          <AnnouncementBell client:only="react" />
          <AuthButton client:only="react" />
        </div>
      </header>

      <!-- Page content -->
      <main class="darkroom-grid relative z-0 flex-1 p-6">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>

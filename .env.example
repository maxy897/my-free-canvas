# ============================================
# Environment Configuration Template
# ============================================
# Copy this file to .env (frontend/build scripts) and/or apps/worker/.dev.vars
# (local Wrangler Worker variables), then fill in your values.
#
# For deployed Workers, use `wrangler secret put` for secrets rather than
# committing them to wrangler.toml or to this file.
# ============================================

# --- General ---
ENVIRONMENT=development

# --- Frontend ---
# Public Worker API URL the browser will call.
PUBLIC_API_URL=http://localhost:8787
# Public web URL — used for OAuth redirects, CORS, etc.
FRONTEND_URL=http://localhost:4321

# --- Authentication (Better Auth + OAuth) ---
# Required for auth/session signing. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-random-32-byte-hex-string-here

# OAuth providers (optional; set only the providers you enable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=

# LinuxDo Connect OAuth defaults (optional overrides)
LINUXDO_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
LINUXDO_TOKEN_URL=https://connect.linux.do/oauth2/token
LINUXDO_USERINFO_URL=https://connect.linux.do/api/user
LINUXDO_SCOPES=user
LINUXDO_TOKEN_AUTH_METHOD=client_secret_post
LINUXDO_USE_PKCE=true

# Additional trusted origins (comma-separated; optional)
ADDITIONAL_TRUSTED_ORIGINS=

# --- Cloudflare bindings ---
# D1/KV/R2 bindings are configured in apps/worker/wrangler.toml (copied from
# apps/worker/wrangler.toml.example). Do not put real Cloudflare IDs in git.
R2_PUBLIC_URL=

# --- Task Processing (Deno Relay) ---
DENO_RELAY_URL=http://localhost:8001
CANVAS_WEBHOOK_BASE_URL=http://localhost:8787
# Shared secret signing webhook calls between Worker <-> Relay.
DENO_SECRET=dev-webhook-secret

# External asset re-hosting service used by some image providers (optional).
ASSET_SERVICE_URL=
ASSET_SERVICE_API_KEY=

# --- AI Image Generation Providers (optional) ---
CHATGPT2API_BASE_URL=
CHATGPT2API_KEY=
FAL_API_KEY=
REPLICATE_API_TOKEN=
KLING_API_KEY=
HF_SPACES_URL=

# --- Telegram Backup Storage (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
